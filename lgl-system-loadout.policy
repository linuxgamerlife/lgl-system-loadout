<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
  "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
  "http://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">

<policyconfig>

  <vendor>LinuxGamerLife</vendor>
  <vendor_url>https://github.com/linuxgamerlife/lgl-system-loadout</vendor_url>

  <action id="com.linuxgamerlife.lgl-system-loadout.run-helper">

    <description>Run LGL System Loadout privileged helper</description>
    <message>LGL System Loadout needs administrator privileges to install packages on your system.</message>

    <icon_name>lgl-system-loadout</icon_name>

    <defaults>
      <!-- auth_admin: require authentication every time, no credential caching.
           The helper runs for the lifetime of the install session, so _keep
           is not needed and would leave credentials cached unnecessarily. -->
      <allow_any>auth_admin</allow_any>
      <allow_inactive>auth_admin</allow_inactive>
      <allow_active>auth_admin</allow_active>
    </defaults>

    <!-- Points to the helper binary, not the GUI.
         The GUI itself never runs as root. -->
    <annotate key="org.freedesktop.policykit.exec.path">/usr/libexec/lgl-system-loadout/lgl-system-loadout-helper</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">false</annotate>

  </action>

</policyconfig>
